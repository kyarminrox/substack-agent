# Copy to .env and fill in as needed
NODE_ENV=development
MEDIUM_TOKEN=
SUBSTACK_AUTH_DIR=playwright/.auth
SUBSTACK_BASE_URL=https://substack.com
# Optional: URL of your publication, e.g. https://yourpub.substack.com
SUBSTACK_PUBLICATION_URL=
# Set to "false" to see the browser window
SUBSTACK_HEADLESS=true
# When true, publish actions are only logged
SAFE_MODE=false
